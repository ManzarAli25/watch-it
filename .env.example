# --- VLM backend (OpenAI-compatible vision endpoint) ---
# Point at any OpenAI-compatible /chat/completions server:
#   local vLLM serving Qwen2.5-VL, Alibaba DashScope compat mode, OpenRouter, etc.
WATCH_VLM_BASE_URL=http://localhost:8000/v1
WATCH_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
WATCH_VLM_API_KEY=
WATCH_VLM_MAX_TOKENS=4096

# Set WATCH_VLM_MODEL=stub to run with a deterministic fake provider (no key, no network).

# --- Sampling / cost controls ---
WATCH_MAX_FRAMES=32
WATCH_FRAME_MAX_EDGE=768
WATCH_SCENE_THRESHOLD=27.0
WATCH_FALLBACK_INTERVAL=5.0
# Reject videos longer than this many seconds (0 disables). Default 30 min.
WATCH_MAX_DURATION=1800

# --- Misc ---
# Leave empty to use the OS temp dir.
WATCH_TEMP_DIR=
# Phase 2 hook; no effect yet.
WATCH_OCR=0
